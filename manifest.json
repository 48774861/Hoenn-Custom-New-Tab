{
  "name": " ",
  "version": "1.0",
  "manifest_version": 3,

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "options_page": "options.html",

  "web_accessible_resources": [
    {
      "resources": [
        "wallpaper.mp4",
        "settings.png",
        "icons/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "permissions": ["bookmarks", "downloads", "tabs", "storage"]
}